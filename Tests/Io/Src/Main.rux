// Exercises the OS-interaction (I/O) thunks the linker provides on hosts
// without native Win32: GetStdHandle and WriteConsoleW. The codegen lowers
// these extern calls with the Win64 register layout, and each backend maps
// them onto host primitives:
//   - Windows: the real kernel32 functions
//   - Linux/FreeBSD: ELF syscall thunks (write)
//   - macOS: Mach-O syscall thunks (write, BSD class mask)
//
// A `c16"..."` literal is a Slice<char16> (UTF-16). `.data` yields a pointer
// into read-only data and `.length` the element count, which is exactly what
// WriteConsoleW consumes. Tests/run_io_test.sh builds this and asserts the
// printed output, so it doubles as a regression test for the thunks.

@[Import(lib: "kernel32")]
extern func GetStdHandle(handle: int) -> int;

@[Import(lib: "kernel32")]
extern func WriteConsoleW(handle: int, buffer: *char16, count: uint64) -> bool;

func Main() -> int {
    let text = c16"Hello from a Rux binary via I/O thunks!\n";
    let stdout = GetStdHandle(-11); // STD_OUTPUT_HANDLE
    WriteConsoleW(stdout, text.data, text.length);
    return 0;
}
